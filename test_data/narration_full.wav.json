19, "start": 81.04, "end": 81.52}, {"word": "for", "start_offset": 1019, "end_offset": 1020, "start": 81.52, "end": 81.60000000000001}, {"word": "the", "start_offset": 1020, "end_offset": 1022, "start": 81.60000000000001, "end": 81.76}, {"word": "seismic", "start_offset": 1022, "end_offset": 1029, "start": 81.76, "end": 82.32000000000001}, {"word": "consequences", "start_offset": 1029, "end_offset": 1035, "start": 82.32000000000001, "end": 82.8}, {"word": "of", "start_offset": 1035, "end_offset": 1037, "start": 82.8, "end": 82.96000000000001}, {"word": "this", "start_offset": 1037, "end_offset": 1039, "start": 82.96000000000001, "end": 83.12}, {"word": "power", "start_offset": 1039, "end_offset": 1044, "start": 83.12, "end": 83.52}, {"word": "shift.", "start_offset": 1044, "end_offset": 1051, "start": 83.52, "end": 84.08}, {"word": "Khamenei's", "start_offset": 1055, "end_offset": 1066, "start": 84.4, "end": 85.28}, {"word": "legacy", "start_offset": 1066, "end_offset": 1071, "start": 85.28, "end": 85.68}, {"word": "will", "start_offset": 1071, "end_offset": 1073, "start": 85.68, "end": 85.84}, {"word": "ultimately", "start_offset": 1073, "end_offset": 1078, "start": 85.84, "end": 86.24}, {"word": "be", "start_offset": 1078, "end_offset": 1079, "start": 86.24, "end": 86.32000000000001}, {"word": "defined", "start_offset": 1079, "end_offset": 1085, "start": 86.32000000000001, "end": 86.8}, {"word": "by", "start_offset": 1085, "end_offset": 1086, "start": 86.8, "end": 86.88}, {"word": "his", "start_offset": 1086, "end_offset": 1088, "start": 86.88, "end": 87.04}, {"word": "iron", "start_offset": 1088, "end_offset": 1091, "start": 87.04, "end": 87.28}, {"word": "fist", "start_offset": 1091, "end_offset": 1095, "start": 87.28, "end": 87.60000000000001}, {"word": "and", "start_offset": 1095, "end_offset": 1097, "start": 87.60000000000001, "end": 87.76}, {"word": "a", "start_offset": 1097, "end_offset": 1098, "start": 87.76, "end": 87.84}, {"word": "four-decade", "start_offset": 1098, "end_offset": 1107, "start": 87.84, "end": 88.56}, {"word": "fixation", "start_offset": 1107, "end_offset": 1112, "start": 88.56, "end": 88.96000000000001}, {"word": "on", "start_offset": 1112, "end_offset": 1114, "start": 88.96000000000001, "end": 89.12}, {"word": "challenging", "start_offset": 1114, "end_offset": 1120, "start": 89.12, "end": 89.60000000000001}, {"word": "Western", "start_offset": 1120, "end_offset": 1125, "start": 89.60000000000001, "end": 90.0}, {"word": "interests.", "start_offset": 1125, "end_offset": 1131, "start": 90.0, "end": 90.48}], "segment": [{"text": "Iran has entered a state of survival following the death of Supreme Leader Ayatollah Ali Khamenei in a series of targeted airstrikes.", "start": 0.0, "end": 7.5200000000000005}, {"text": "The 86-year-old cleric was killed after decades of trading threats and missiles with Israel and the United States.", "start": 7.76, "end": 13.52}, {"text": "Satellite imagery confirms the destruction of his secure compound in downtown Tehran, now reduced to a grey mass.", "start": 13.76, "end": 20.16}, {"text": "While the strike marks the end of an era for a nation that has known only one leader for 40 years, the Islamic Republic's system of rule remains functional.", "start": 20.400000000000002, "end": 28.080000000000002}, {"text": "Security has been tightened across major cities as volunteer paramilitaries and armed police patrol the streets to prevent potential uprisings.", "start": 28.240000000000002, "end": 35.92}, {"text": "Despite calls from the West for a popular revolt, ordinary Iranians appear to be prioritizing safety over civil unrest.", "start": 36.160000000000004, "end": 43.28}, {"text": "For now, a temporary council consisting of the heads of the judiciary, legislature, and executive will govern the country according to the constitution.", "start": 43.52, "end": 52.24}, {"text": "Experts suggest the Islamic Revolutionary Guard Corps is poised to seize even greater political and economic influence during this transition.", "start": 52.56, "end": 60.0}, {"text": "The leadership vacuum also raises urgent questions regarding Iran's nuclear policy and its long-standing religious edict against weaponization.", "start": 60.160000000000004, "end": 68.24}, {"text": "With Khamenei gone, internal voices seeking greater flexibility in the country's pursuit of deterrence may finally gain traction.", "start": 68.4, "end": 75.52}, {"text": "Internationally, the assassination has drawn sharp condemnation from China and Russia, while the region braces for the seismic consequences of this power shift.", "start": 75.84, "end": 84.08}, {"text": "Khamenei's legacy will ultimately be defined by his iron fist and a four-decade fixation on challenging Western interests.", "start": 84.4, "end": 90.48}]}, "engine": "parakeet"}